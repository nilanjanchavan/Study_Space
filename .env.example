# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─────────────────────────────────────────────
# PostgreSQL connection
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://studyuser:studypass@localhost:5432/studyworkspace?schema=public"

# ─────────────────────────────────────────────
# Auth / JWT
# IMPORTANT: replace these with strong random strings in production.
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ─────────────────────────────────────────────
JWT_ACCESS_SECRET=dev_access_secret_change_me_e1f4a2b9c7d8_6a3f
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_9b2e7c4d1a8f_5e2b
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30

# ─────────────────────────────────────────────
# Rate limiting (auth endpoints)
# ─────────────────────────────────────────────
AUTH_RATE_WINDOW_MS=900000
AUTH_RATE_MAX=10
